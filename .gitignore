# =============================================================================
# VehicleSure Project - Master .gitignore
# =============================================================================

# ### System Files ###
.DS_Store
Thumbs.db
*.swp
*~
.nfs*

# ### IDE and Editors ###
.idea/
.vscode/
*.iws
*.iml
*.ipr
out/
.history/
.project
.classpath
.factorypath
.settings/
.springBeans
.sts4-cache
.apt_generated

# ### Build Artifacts ###
# Backend (WillowShield)
WillowShield/target/
WillowShield/build/
WillowShield/.mvn/wrapper/maven-wrapper.jar

# Frontend (Angular)
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out/
frontend/.angular/
frontend/coverage/

# ### Dependencies ###
node_modules/
frontend/node_modules/

# ### Sensitive Files ###
.env
*.env
*.jks
*.p12
*.key
secrets.*

# ### Logs and Temporary Files ###
# General logs and text outputs
*.log
*.txt
!README.md

# Project specific backend logs
WillowShield/*_log.txt
WillowShield/test_results.log

# Project specific frontend logs/outputs
frontend/*.log
frontend/*.txt
frontend/*.py
frontend/test-debug.spec.ts
frontend/__screenshots__/

# ### Local Data ###
# Ignore local user uploads
WillowShield/uploads/
